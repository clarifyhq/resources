# ─────────────────────────────────────────────────────────────────────────────
# Fireflies → Clarify Sync Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See README.md for detailed setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Fireflies ────────────────────────────────────────────────────────────────
# Your Fireflies API key.
# Find it at: https://app.fireflies.ai/integrations/custom/fireflies
# (Settings → Integrations → Fireflies → API Key)
#
# IMPORTANT: Fireflies Business plan or higher is required for production use.
# Free/Pro plans are limited to 50 API requests per day (testing only).
# Business plan allows 60 requests per minute.
FIREFLIES_API_KEY=

# ── Clarify ──────────────────────────────────────────────────────────────────
# Your Clarify workspace slug (the part after clarify.ai/ in your URL).
# Example: if your Clarify URL is https://app.clarify.ai/mycompany, use "mycompany"
CLARIFY_WORKSPACE=

# Your Clarify API key.
# Find it at: Clarify → Settings → API Keys
CLARIFY_API_KEY=

# ── Sync Behavior ────────────────────────────────────────────────────────────
# How many days back to look for new transcripts on each sync run.
# Default: 7. For the first run, use --backfill to get everything.
SYNC_WINDOW_DAYS=7

# Domains to identify as "internal" (your company's domains).
# Comma-separated. Used to classify participants as internal vs external.
# Example: yourcompany.com,yourcompany.io
INTERNAL_DOMAINS=
